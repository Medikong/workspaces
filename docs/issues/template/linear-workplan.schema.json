{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kt-cloudnative-study.local/schemas/linear-workplan.schema.json",
  "title": "KT CloudNative Study Linear Workplan",
  "description": "Local planning schema for turning project scenarios into Linear or GitHub Project issues with dependency metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "defaults", "tasks"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "milestones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/milestone"
      },
      "default": []
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team"],
      "properties": {
        "team": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1,
          "default": "Backlog"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "assignee": {
          "type": ["string", "null"]
        },
        "labels": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "$ref": "#/$defs/localId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string"
        },
        "start_date": {
          "$ref": "#/$defs/date"
        },
        "target_date": {
          "$ref": "#/$defs/date"
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_id", "title", "description", "depends_on"],
      "properties": {
        "local_id": {
          "$ref": "#/$defs/localId"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["planning", "design", "implementation", "test", "experiment", "docs", "ops", "security"],
          "default": "implementation"
        },
        "team": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "labels": {
          "$ref": "#/$defs/stringList"
        },
        "milestone": {
          "type": "string"
        },
        "cycle": {
          "type": "string"
        },
        "assignee": {
          "type": ["string", "null"]
        },
        "estimate": {
          "type": "number",
          "minimum": 0
        },
        "dueDate": {
          "$ref": "#/$defs/date"
        },
        "parent": {
          "$ref": "#/$defs/localId"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localId"
          },
          "uniqueItems": true
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localId"
          },
          "uniqueItems": true
        },
        "related_to": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localId"
          },
          "uniqueItems": true
        },
        "done_when": {
          "$ref": "#/$defs/stringList"
        },
        "evidence": {
          "$ref": "#/$defs/stringList"
        },
        "metrics": {
          "$ref": "#/$defs/stringList"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          },
          "default": []
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "localId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    }
  }
}
