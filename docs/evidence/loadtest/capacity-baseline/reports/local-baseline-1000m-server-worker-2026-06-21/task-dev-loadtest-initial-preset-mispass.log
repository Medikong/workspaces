task: [dev:loadtest] set -eu
preset="${PRESET:-${LOADTEST_PRESET:-${LOADTEST_SCENARIO_PRESET:-}}}"
scenario="${SCENARIO:-${LOADTEST_SCENARIO:-}}"
if [ -z "${scenario}" ] && [ -n "${preset}" ]; then
  scenario="reservation-journey-load-test"
fi
scenario="${scenario:-capacity-baseline-load-test}"
if [ "${scenario}" = "capacity-baseline-load-test" ]; then
  preset="${preset:-local-smoke}"
  scenario_values_file="${LOADTEST_SCENARIO_VALUES_FILE:-}"
  if [ -z "${scenario_values_file}" ] && [ -n "${preset}" ]; then
    scenario_base="${scenario%-load-test}"
    for candidate in \
      "platform/loadtest/values/presets/${scenario}/${preset}.yaml" \
      "platform/loadtest/values/presets/${scenario_base}/${preset}.yaml" \
      "platform/loadtest/values/presets/${preset}.yaml"; do
      if [ -f "${candidate}" ]; then
        scenario_values_file="${candidate}"
        break
      fi
    done
  fi
  if [ -z "${scenario_values_file}" ] && [ -f "platform/loadtest/values/scenarios/${scenario}.yaml" ]; then
    scenario_values_file="platform/loadtest/values/scenarios/${scenario}.yaml"
  fi
  capacity_cpu_request="${LOADTEST_CAPACITY_BASELINE_CPU_REQUEST:-}"
  capacity_auth_token_ttl_seconds="${LOADTEST_CAPACITY_BASELINE_AUTH_TOKEN_TTL_SECONDS:-}"
  if [ -z "${capacity_cpu_request}" ] && [ -n "${scenario_values_file}" ]; then
    if command -v ruby >/dev/null 2>&1; then
      capacity_cpu_request="$(ruby -ryaml -e 'value = YAML.load_file(ARGV[0]).dig("scenarios", "capacityBaseline", "fixedConditions", "cpuRequest"); puts value if value' "${scenario_values_file}")"
    fi
  fi
  if [ -z "${capacity_auth_token_ttl_seconds}" ] && [ -n "${scenario_values_file}" ]; then
    if command -v ruby >/dev/null 2>&1; then
      capacity_auth_token_ttl_seconds="$(ruby -ryaml -e 'value = YAML.load_file(ARGV[0]).dig("scenarios", "capacityBaseline", "fixedConditions", "authTokenTtlSeconds"); puts value if value' "${scenario_values_file}")"
    fi
  fi
  capacity_cpu_request="${capacity_cpu_request:-500m}"
  capacity_auth_token_ttl_seconds="${capacity_auth_token_ttl_seconds:-7200}"
  printf 'Capacity baseline service CPU request=%s auth token ttl=%ss values=%s\n' "${capacity_cpu_request}" "${capacity_auth_token_ttl_seconds}" "${scenario_values_file:-default}"
  task dev:services \
    LOCAL_DOCKER_DESKTOP_ENV=local-capacity-baseline \
    DEV_ROLLOUT_ID="capacity-baseline-$(date -u +%Y%m%dT%H%M%SZ)" \
    LOADTEST_CAPACITY_BASELINE_CPU_REQUEST="${capacity_cpu_request}" \
    LOADTEST_CAPACITY_BASELINE_AUTH_TOKEN_TTL_SECONDS="${capacity_auth_token_ttl_seconds}"
  warmup_seconds="${LOADTEST_CAPACITY_BASELINE_PROMETHEUS_WARMUP_SECONDS:-90}"
  printf 'Waiting %ss for Prometheus scrape warmup before capacity baseline run.\n' "${warmup_seconds}"
  sleep "${warmup_seconds}"
else
  if [ "${scenario}" = "reservation-journey-load-test" ] && { [ "${preset}" = "local-hpa-spike-3m" ] || [ "${preset}" = "local-hpa-spike-smoke-1m" ] || [ "${preset}" = "local-hpa-spike-scaleout-6m" ]; }; then
    printf 'Redeploying local dev services with HPA enabled for preset=%s.\n' "${preset}"
    task dev:services \
      LOCAL_DOCKER_DESKTOP_ENV=local-hpa-spike \
      DEV_ROLLOUT_ID="local-hpa-spike-$(date -u +%Y%m%dT%H%M%SZ)"
    if [ "${preset}" = "local-hpa-spike-smoke-1m" ]; then
      warmup_seconds="${LOADTEST_LOCAL_HPA_SPIKE_WARMUP_SECONDS:-15}"
    else
      warmup_seconds="${LOADTEST_LOCAL_HPA_SPIKE_WARMUP_SECONDS:-60}"
    fi
    printf 'Waiting %ss for metrics-server/HPA warmup before local HPA spike run.\n' "${warmup_seconds}"
    sleep "${warmup_seconds}"
  fi
fi

Capacity baseline service CPU request=1000m auth token ttl=7200s values=platform/loadtest/values/presets/capacity-baseline/local-smoke.yaml
task: [dev:services] set -eu
image_registry='localhost:5001'
image_namespace=''
rollout_id='capacity-baseline-20260621T061516Z'
if [ -z "${rollout_id}" ]; then
  rollout_id="$(date -u +%Y%m%dT%H%M%SZ)"
fi
if [ -n "${image_namespace}" ]; then
  image_registry="${image_registry%/}/${image_namespace#/}"
fi
extra_helm_args=""
if [ "local-capacity-baseline" = "local-capacity-baseline" ]; then
  capacity_cpu_request='1000m'
  capacity_cpu_request="${capacity_cpu_request:-${LOADTEST_CAPACITY_BASELINE_CPU_REQUEST:-500m}}"
  capacity_auth_token_ttl_seconds='7200'
  capacity_auth_token_ttl_seconds="${capacity_auth_token_ttl_seconds:-${LOADTEST_CAPACITY_BASELINE_AUTH_TOKEN_TTL_SECONDS:-7200}}"
  extra_helm_args="${extra_helm_args} --set hpa.enabled=false"
  extra_helm_args="${extra_helm_args} --set-string container.resources.requests.cpu=${capacity_cpu_request}"
  extra_helm_args="${extra_helm_args} --set container.resources.limits.cpu=null"
  extra_helm_args="${extra_helm_args} --set nodeSelector=null"
  extra_helm_args="${extra_helm_args} --set deployment.podAnnotations.sidecar\\.istio\\.io/proxyCPULimit=null"
fi
if [ "local-capacity-baseline" = "local-hpa-spike" ]; then
  extra_helm_args="${extra_helm_args} --set nodeSelector=null"
fi
yaml_section_field() {
  awk -v section="$2" -v wanted="$3" '
    $1 == section ":" { in_section = 1; next }
    in_section && /^[^[:space:]]/ { in_section = 0 }
    in_section {
      line = $0
      sub(/^[[:space:]]+/, "", line)
      key = line
      sub(/:.*/, "", key)
      if (key == wanted) {
        sub(/^[^:]*:[[:space:]]*/, "", line)
        gsub(/^"|"$/, "", line)
        print line
        exit
      }
    }
  ' "$1"
}
pids=""
for service in auth concert notification payment reservation ticket; do
  service_file="values/services/${service}.yaml"
  if [ ! -f "${service_file}" ]; then
    printf 'Unknown DEV_SERVICES entry: %s (expected values/services/%s.yaml).\n' "${service}" "${service}" >&2
    exit 2
  fi
  service="$(basename "${service_file}" .yaml)"
  namespace="$(yaml_section_field "${service_file}" app namespace)"
  release="${service}-local-docker-desktop"
  service_helm_args="${extra_helm_args}"
  override_file="values/overrides/local-capacity-baseline/${service}.yaml"
  override_args=""
  if [ -f "${override_file}" ]; then
    override_args="-f ${override_file}"
  fi
  if [ "local-capacity-baseline" = "local-capacity-baseline" ] && [ "${service}" = "auth" ]; then
    service_helm_args="${service_helm_args} --set-string container.env[1].value=${capacity_auth_token_ttl_seconds}"
  fi
  (
    helm upgrade --install "${release}" charts/medikong-service \
      --namespace "${namespace}" \
      --create-namespace \
      -f values/base.yaml \
      -f "${service_file}" \
      -f values/env/local-capacity-baseline.yaml \
      ${override_args} \
      --set-string image.registry="${image_registry}" \
      --set-string image.tag="dev" \
      --set-string image.pullPolicy=Always \
      --set-string 'deployment.podAnnotations.medikong\.io/dev-rollout-id='"${rollout_id}" \
      ${service_helm_args}
  ) &
  pids="${pids} $!"
done
failed=0
for pid in ${pids}; do
  if ! wait "${pid}"; then
    failed=1
  fi
done
if [ "${failed}" -ne 0 ]; then
  exit 1
fi
if [ "local-capacity-baseline" = "local-capacity-baseline" ]; then
  for service in auth concert notification payment reservation ticket; do
    service_file="values/services/${service}.yaml"
    if [ ! -f "${service_file}" ]; then
      printf 'Unknown DEV_SERVICES entry: %s (expected values/services/%s.yaml).\n' "${service}" "${service}" >&2
      exit 2
    fi
    app_name="$(yaml_section_field "${service_file}" app name)"
    namespace="$(yaml_section_field "${service_file}" app namespace)"
    kubectl scale "deployment/${app_name}" -n "${namespace}" --replicas=1
  done
fi
pids=""
rollout_failures="$(mktemp)"
diagnose_rollout_failure() {
  namespace="$1"
  app_name="$2"
  printf '\n===== Rollout diagnostics: %s/%s =====\n' "${namespace}" "${app_name}" >&2
  kubectl get deployment "${app_name}" -n "${namespace}" -o wide >&2 || true
  kubectl describe deployment "${app_name}" -n "${namespace}" >&2 || true
  kubectl get rs,pods,hpa -n "${namespace}" -l "app=${app_name}" -o wide >&2 || true
  kubectl describe pods -n "${namespace}" -l "app=${app_name}" >&2 || true
  kubectl top pods -n "${namespace}" -l "app=${app_name}" >&2 || true
  kubectl get events -n "${namespace}" --sort-by=.lastTimestamp >&2 | tail -n 40 >&2 || true
  for pod in $(kubectl get pods -n "${namespace}" -l "app=${app_name}" -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null || true); do
    printf '\n----- Recent logs: %s/%s -----\n' "${namespace}" "${pod}" >&2
    kubectl logs -n "${namespace}" "${pod}" --all-containers --tail=80 --prefix=true >&2 || true
  done
}
for service in auth concert notification payment reservation ticket; do
  service_file="values/services/${service}.yaml"
  if [ ! -f "${service_file}" ]; then
    printf 'Unknown DEV_SERVICES entry: %s (expected values/services/%s.yaml).\n' "${service}" "${service}" >&2
    exit 2
  fi
  app_name="$(yaml_section_field "${service_file}" app name)"
  namespace="$(yaml_section_field "${service_file}" app namespace)"
  (
    if ! kubectl rollout status "deployment/${app_name}" -n "${namespace}" --timeout=180s; then
      printf '%s %s\n' "${namespace}" "${app_name}" >> "${rollout_failures}"
      exit 1
    fi
  ) &
  pids="${pids} $!"
done
failed=0
for pid in ${pids}; do
  if ! wait "${pid}"; then
    failed=1
  fi
done
if [ "${failed}" -ne 0 ]; then
  if [ -s "${rollout_failures}" ]; then
    sort -u "${rollout_failures}" | while read -r namespace app_name; do
      diagnose_rollout_failure "${namespace}" "${app_name}"
    done
  fi
  rm -f "${rollout_failures}"
  exit 1
fi
rm -f "${rollout_failures}"

