task: [kong-rate-limit:disable] set -eu
minute="1000000"
for plugin in ticketing-rate-limit-concerts ticketing-rate-limit-reservations ticketing-rate-limit-payments ticketing-rate-limit-tickets ticketing-rate-limit-notifications; do
  printf 'Raising Kong rate limit plugin=%s minute=%s\n' "${plugin}" "${minute}"
  kubectl patch kongclusterplugin "${plugin}" \
    --type=merge \
    -p "{\"config\":{\"minute\":${minute},\"policy\":\"local\"}}"
done

