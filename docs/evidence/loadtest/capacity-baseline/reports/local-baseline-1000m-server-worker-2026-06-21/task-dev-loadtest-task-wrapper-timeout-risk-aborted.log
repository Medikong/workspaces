apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: "read-api-loadtest-scale-out-reader"
  labels:
    app.kubernetes.io/name: "read-api-loadtest"
    app.kubernetes.io/instance: "read-api-loadtest"
    app.kubernetes.io/part-of: medikong
    app.kubernetes.io/managed-by: "Helm"
    helm.sh/chart: "read-api-loadtest-0.1.0"
    medikong.io/environment: "local"
    medikong.io/test-type: "loadtest"
    medikong.io/scenario: "capacity-baseline-load-test"
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: "read-api-loadtest-scale-out-reader"
subjects:
