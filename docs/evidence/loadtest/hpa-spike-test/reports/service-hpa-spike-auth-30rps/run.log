task: [render] set -eu
values_file="${LOADTEST_VALUES_FILE:-values/local.yaml}"
scenario_values_file="${LOADTEST_SCENARIO_VALUES_FILE:-}"
preset="${PRESET:-${LOADTEST_PRESET:-${LOADTEST_SCENARIO_PRESET:-auth-30rps}}}"
scenario="${LOADTEST_SCENARIO:-${SCENARIO:-service-hpa-spike-load-test}}"
if [ -z "${scenario}" ] && [ -n "${preset}" ]; then
  scenario="reservation-journey-load-test"
fi
if [ -z "${scenario_values_file}" ] && [ -n "${preset}" ]; then
  scenario_base="${scenario%-load-test}"
  for candidate in \
    "values/presets/${scenario}/${preset}.yaml" \
    "values/presets/${scenario_base}/${preset}.yaml" \
    "values/presets/${preset}.yaml"; do
    if [ -f "${candidate}" ]; then
      scenario_values_file="${candidate}"
      break
    fi
  done
  if [ -z "${scenario_values_file}" ]; then
    printf 'Unknown preset=%s for scenario=%s.\n' "${preset}" "${scenario}" >&2
    exit 2
  fi
fi
if [ -z "${scenario_values_file}" ] && [ -n "${scenario}" ] && [ -f "values/scenarios/${scenario}.yaml" ]; then
  scenario_values_file="values/scenarios/${scenario}.yaml"
fi
values_args="-f ${values_file}"
if [ -n "${scenario_values_file}" ]; then
  values_args="${values_args} -f ${scenario_values_file}"
fi
capacity_service_steps="${LOADTEST_CAPACITY_BASELINE_SERVICE_STEPS:-}"
if [ -n "${capacity_service_steps}" ]; then
  values_args="${values_args} --set-json scenarios.capacityBaseline.serviceSteps=${capacity_service_steps}"
fi
image_args=""
if [ "${LOADTEST_IMAGE_OVERRIDE:-}" = "true" ] || [ "${values_file}" = "values/local.yaml" ]; then
  image_ref="$(task image-ref --silent)"
  image_registry="${image_ref%/*}"
  image_name_tag="${image_ref##*/}"
  image_repository="${image_name_tag%:*}"
  image_tag="${image_name_tag##*:}"
  image_args="--set-string image.registry=${image_registry} --set-string image.repository=${image_repository} --set-string image.tag=${image_tag}"
fi
helm template read-api-loadtest . \
  ${values_args} \
  --namespace loadtest \
  ${image_args}

