task: [secret-local] set -eu
kubectl create namespace loadtest --dry-run=client -o yaml | kubectl apply -f -
kubectl label namespace loadtest app.kubernetes.io/managed-by=Helm --overwrite
kubectl annotate namespace loadtest \
  meta.helm.sh/release-name=read-api-loadtest \
  meta.helm.sh/release-namespace=loadtest \
  --overwrite
kubectl -n loadtest create secret generic read-api-loadtest-credentials \
  --from-literal=LOADTEST_PROVIDER_EMAIL="${LOADTEST_PROVIDER_EMAIL:-provider@example.com}" \
  --from-literal=LOADTEST_PROVIDER_PASSWORD="${LOADTEST_PROVIDER_PASSWORD:-provider1234}" \
  --from-literal=LOADTEST_ADMIN_EMAIL="${LOADTEST_ADMIN_EMAIL:-admin@example.com}" \
  --from-literal=LOADTEST_ADMIN_PASSWORD="${LOADTEST_ADMIN_PASSWORD:-admin1234}" \
  --dry-run=client -o yaml | kubectl apply -f -

