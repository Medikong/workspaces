task: [dev:registry] set -eu
registry='localhost:5001'
container='medikong-registry'
case "${registry}" in
  localhost:*|127.0.0.1:*) ;;
  *)
    printf 'DEV_REGISTRY=%s is not a local Docker Desktop registry; skipping local registry bootstrap.\n' "${registry}"
    exit 0
    ;;
esac
if ! command -v docker >/dev/null 2>&1; then
  printf '%s\n' 'docker command is required for task dev:registry.' >&2
  exit 2
fi
host_port="${registry##*:}"
if [ "${host_port}" = "${registry}" ]; then
  host_port=5000
fi
if docker inspect "${container}" >/dev/null 2>&1; then
  running_container="$(docker ps --filter "name=^/${container}$" --filter status=running -q)"
  if [ -z "${running_container}" ]; then
    docker start "${container}" >/dev/null
  fi
else
  docker run -d --restart=always -p "127.0.0.1:${host_port}:5000" --name "${container}" registry:2 >/dev/null
fi
nodes="$(docker ps --filter ancestor=kindest/node -q)"
if [ -z "${nodes}" ]; then
  printf '%s\n' 'No kindest/node containers found. Registry is running, but no node mirror was configured.'
  exit 0
fi
for node in ${nodes}; do
  network="$(docker inspect --format '{{range $name, $_ := .NetworkSettings.Networks}}{{println $name}}{{end}}' "${node}" | head -n 1)"
  if [ -z "${network}" ]; then
    printf 'Could not resolve Docker network for node container %s.\n' "${node}" >&2
    exit 2
  fi
  docker network connect "${network}" "${container}" 2>/dev/null || true
  docker exec "${node}" sh -c "mkdir -p '/etc/containerd/certs.d/${registry}' && printf '%s\n' 'server = \"http://${registry}\"' '' '[host.\"http://${container}:5000\"]' '  capabilities = [\"pull\", \"resolve\"]' > '/etc/containerd/certs.d/${registry}/hosts.toml' && systemctl restart containerd"
done

