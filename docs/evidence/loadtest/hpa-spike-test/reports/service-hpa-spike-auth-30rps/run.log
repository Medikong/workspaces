task: [ensure-no-active-loadtest] set -eu
active_jobs="$(kubectl -n loadtest get jobs \
  -l 'app.kubernetes.io/name=read-api-loadtest,medikong.io/scenario!=setup-read-dataset' \
  -o jsonpath='{range .items[?(@.status.active)]}{.metadata.name}{"\n"}{end}')"
if [ -n "${active_jobs}" ]; then
  printf 'Active loadtest Job already exists:\n%s\n' "${active_jobs}" >&2
  printf 'Wait until it finishes, or delete the Job manually before starting another run.\n' >&2
  exit 1
fi

task: [setup-dataset] set -eu
run_id="manual-$(date -u +%Y%m%d%H%M%S)"
job_name="read-api-loadtest-dataset-${run_id}"
helm upgrade read-api-loadtest . \
  --namespace loadtest \
  --reuse-values \
  --set manualRuns.dataset.enabled=true \
  --set-string manualRuns.dataset.runId="${run_id}" \
  --set manualRuns.read.enabled=false \
  --set-string manualRuns.read.runId=""
deadline=$(( $(date +%s) + 1800 ))
while true; do
  complete="$(kubectl -n loadtest get job "${job_name}" -o jsonpath='{.status.succeeded}' 2>/dev/null || true)"
  failed="$(kubectl -n loadtest get job "${job_name}" -o jsonpath='{.status.failed}' 2>/dev/null || true)"
  if [ "${failed:-0}" -ge 1 ]; then
    kubectl -n loadtest logs "job/${job_name}" --tail=120 || true
    kubectl -n loadtest describe job "${job_name}" || true
    kubectl -n loadtest describe pods -l "job-name=${job_name}" || true
    exit 1
  fi
  if [ "${complete:-0}" -ge 1 ]; then
    printf 'Dataset setup Job completed job=%s\n' "${job_name}"
    exit 0
  fi
  if [ "$(date +%s)" -ge "${deadline}" ]; then
    kubectl -n loadtest logs "job/${job_name}" --tail=120 || true
    kubectl -n loadtest describe job "${job_name}" || true
    kubectl -n loadtest describe pods -l "job-name=${job_name}" || true
    printf 'Timed out waiting for job/%s.\n' "${job_name}" >&2
    exit 1
  fi
  sleep 3
done

