task: [loadtest:ensure-no-active-loadtest] set -eu
active_jobs="$(kubectl -n loadtest get jobs \
  -l 'app.kubernetes.io/name=read-api-loadtest,medikong.io/scenario!=setup-read-dataset' \
  -o jsonpath='{range .items[?(@.status.active)]}{.metadata.name}{"\n"}{end}')"
if [ -n "${active_jobs}" ]; then
  printf 'Active loadtest Job already exists:\n%s\n' "${active_jobs}" >&2
  printf 'Wait until it finishes, or delete the Job manually before starting another run.\n' >&2
  exit 1
fi

task: [loadtest:run-local] set -eu
preset="${PRESET:-${LOADTEST_PRESET:-${LOADTEST_SCENARIO_PRESET:-auth-30rps}}}"
scenario="${SCENARIO:-${LOADTEST_SCENARIO:-service-hpa-spike-load-test}}"
if [ -z "${scenario}" ] && [ -n "${preset}" ]; then
  scenario="reservation-journey-load-test"
fi
scenario="${scenario:-read-api-baseline}"
scenario_values_file="${LOADTEST_SCENARIO_VALUES_FILE:-}"
if [ -z "${scenario_values_file}" ] && [ -n "${preset}" ]; then
  scenario_base="${scenario%-load-test}"
  for candidate in \
    "values/presets/${scenario}/${preset}.yaml" \
    "values/presets/${scenario_base}/${preset}.yaml" \
    "values/presets/${preset}.yaml"; do
    if [ -f "${candidate}" ]; then
      scenario_values_file="${candidate}"
      break
    fi
  done
  if [ -z "${scenario_values_file}" ]; then
    printf 'Unknown preset=%s for scenario=%s.\n' "${preset}" "${scenario}" >&2
    exit 2
  fi
fi
scenario_values_file="${scenario_values_file:-values/scenarios/${scenario}.yaml}"
if [ ! -f "${scenario_values_file}" ]; then
  printf 'Unknown or missing scenario values file: %s\n' "${scenario_values_file}" >&2
  printf 'Set SCENARIO=<name>, PRESET=<preset-name>, or LOADTEST_SCENARIO_VALUES_FILE=<path>.\n' >&2
  exit 2
fi
export SCENARIO="${scenario}"
export LOADTEST_SCENARIO_VALUES_FILE="${scenario_values_file}"
disable_kong_rate_limit="${LOADTEST_DISABLE_KONG_RATE_LIMIT:-}"
if [ -z "${disable_kong_rate_limit}" ]; then
  case "${scenario}" in
    reservation-journey-load-test|reservation-create-load-test|reservation-seat-contention-load-test|ticket-service-read-load-test|capacity-baseline-load-test|service-hpa-spike-load-test)
      disable_kong_rate_limit="true"
      ;;
  esac
fi
disable_kong_rate_limit="${disable_kong_rate_limit:-false}"
printf 'Running loadtest scenario=%s values=%s disable_kong_rate_limit=%s\n' \
  "${scenario}" "${LOADTEST_SCENARIO_VALUES_FILE}" "${disable_kong_rate_limit}"
if [ "${disable_kong_rate_limit}" = "true" ]; then
  task kong-rate-limit:disable
  trap 'task kong-rate-limit:restore' EXIT
fi
task secret-local
task deploy
case "${scenario}" in
  auth-login-load-test|ticket-service-read-load-test)
    ;;
  *)
  task setup-dataset
    ;;
esac
task run

